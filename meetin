<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meetings — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../css/app.css">
</head>
<body>

<div id="sidebarOverlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.3); z-index:199;"
     onclick="document.getElementById('sidebar').classList.remove('open'); this.style.display='none'"></div>

<div class="app-shell">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="sidebar-logo-mark">&#9670;</div>
            <div><div class="sidebar-logo-text">Club Portal</div><div class="sidebar-logo-sub">Admin Panel</div></div>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-section-label">Main</div>
            <ul class="sidebar-nav">
                <li><a href="dashboard.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M2 11l8-8 8 8v8a1 1 0 01-1 1H3a1 1 0 01-1-1v-8z"/></svg>Dashboard</a></li>
                <li><a href="students.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zm8 0a3 3 0 11-6 0 3 3 0 016 0zM9 13a6 6 0 00-6 6h12a6 6 0 00-6-6z"/></svg>Students</a></li>
            </ul>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-section-label">Manage</div>
            <ul class="sidebar-nav">
                <li><a href="attendance.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>Attendance</a></li>
                <li><a href="meetings.html" class="active"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>Meetings</a></li>
                <li><a href="form-builder.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>Data Form</a></li>
            </ul>
        </div>
        <div class="sidebar-footer">
            <div class="sidebar-user" onclick="logout()">
                <div class="avatar">A</div>
                <div class="sidebar-user-info"><div class="sidebar-user-name">Admin</div><div class="sidebar-user-role">Club Admin</div></div>
            </div>
        </div>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <div style="display:flex; align-items:center; gap:12px;">
                <button class="topbar-menu-btn" id="menuBtn"><svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/></svg></button>
                <div class="topbar-left">
                    <div class="page-title">Weekly Meetings</div>
                    <div class="page-breadcrumb">Schedule and manage club sessions</div>
                </div>
            </div>
            <div class="topbar-right">
                <button class="btn btn-primary" onclick="openModal('addMeetingModal')">+ New Meeting</button>
            </div>
        </div>

        <div class="page-body">
            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title">All Meetings</div>
                    <span class="badge badge-gray" id="meetingCount">0 meetings</span>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Location</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="meetingsTable">
                            <tr><td colspan="6">
                                <div class="empty-state">
                                    <div class="empty-icon">📅</div>
                                    <div class="empty-title">No meetings yet</div>
                                    <div class="empty-desc">Click "New Meeting" to schedule your first session</div>
                                </div>
                            </td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Meeting Modal -->
<div class="modal-overlay" id="addMeetingModal">
    <div class="modal">
        <div class="modal-header">
            <div class="modal-title">Schedule Meeting</div>
            <button class="modal-close" onclick="closeModal('addMeetingModal')">&#x2715;</button>
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label for="mTitle">Meeting Title</label>
                <input type="text" id="mTitle" placeholder="e.g. Weekly Meeting #1">
            </div>
            <div class="form-grid form-grid-2">
                <div class="form-group">
                    <label for="mDate">Date</label>
                    <input type="date" id="mDate">
                </div>
                <div class="form-group">
                    <label for="mTime">Time</label>
                    <input type="time" id="mTime">
                </div>
            </div>
            <div class="form-group">
                <label for="mLocation">Location / Venue</label>
                <input type="text" id="mLocation" placeholder="e.g. Classroom B2-03">
            </div>
            <div class="form-group">
                <label for="mAgenda">Agenda / Notes</label>
                <textarea id="mAgenda" placeholder="What will happen at this meeting?"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('addMeetingModal')">Cancel</button>
            <button class="btn btn-primary" onclick="addMeeting()">Save Meeting</button>
        </div>
    </div>
</div>

<script src="../js/app.js"></script>
<script>
    requireAuth('admin');
    let meetings = [];

    function renderMeetings() {
        const tbody = document.getElementById('meetingsTable');
        document.getElementById('meetingCount').textContent = `${meetings.length} meetings`;
        if (!meetings.length) {
            tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state"><div class="empty-icon">📅</div><div class="empty-title">No meetings yet</div><div class="empty-desc">Click "New Meeting" to schedule your first session</div></div></td></tr>`;
            return;
        }
        const today = new Date().toISOString().split('T')[0];
        tbody.innerHTML = meetings.map((m, i) => {
            const status = m.date > today ? 'upcoming' : m.date === today ? 'today' : 'past';
            const badge = status === 'upcoming' ? 'badge-blue' : status === 'today' ? 'badge-green' : 'badge-gray';
            return `<tr>
                <td><strong>${m.title}</strong></td>
                <td>${formatDate(m.date)}</td>
                <td>${formatTime(m.time)}</td>
                <td>${m.location || '—'}</td>
                <td><span class="badge ${badge}">${status}</span></td>
                <td>
                    <div style="display:flex;gap:6px;">
                        <button class="btn btn-secondary btn-sm" onclick="editMeeting(${i})">Edit</button>
                        <button class="btn btn-danger btn-sm" onclick="deleteMeeting(${i})">Delete</button>
                    </div>
                </td>
            </tr>`;
        }).join('');
    }

    function addMeeting() {
        const title    = document.getElementById('mTitle').value.trim();
        const date     = document.getElementById('mDate').value;
        const time     = document.getElementById('mTime').value;
        const location = document.getElementById('mLocation').value.trim();
        const agenda   = document.getElementById('mAgenda').value.trim();
        if (!title || !date || !time) { showAlert('Title, date and time are required.', 'error'); return; }
        meetings.push({ title, date, time, location, agenda });
        meetings.sort((a, b) => a.date.localeCompare(b.date));
        renderMeetings();
        closeModal('addMeetingModal');
        showAlert('Meeting scheduled!', 'success');
        /* Will save to Supabase in Phase 2 */
        ['mTitle','mDate','mTime','mLocation','mAgenda'].forEach(id => document.getElementById(id).value = '');
    }

    function editMeeting(i) {
        const m = meetings[i];
        document.getElementById('mTitle').value    = m.title;
        document.getElementById('mDate').value     = m.date;
        document.getElementById('mTime').value     = m.time;
        document.getElementById('mLocation').value = m.location;
        document.getElementById('mAgenda').value   = m.agenda;
        meetings.splice(i, 1);
        openModal('addMeetingModal');
    }

    function deleteMeeting(i) {
        if (!confirm('Delete this meeting?')) return;
        meetings.splice(i, 1);
        renderMeetings();
        showAlert('Meeting deleted.', 'info');
    }

    renderMeetings();

    document.getElementById('menuBtn').addEventListener('click', () => {
        const s = document.getElementById('sidebar');
        const o = document.getElementById('sidebarOverlay');
        s.classList.toggle('open');
        o.style.display = s.classList.contains('open') ? 'block' : 'none';
    });
</script>
</body>
</html>
