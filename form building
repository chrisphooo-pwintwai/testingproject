<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Data Form — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../css/app.css">
    <style>
        .field-card { background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:14px 16px; display:flex; align-items:center; gap:12px; margin-bottom:10px; }
        .field-drag  { color:var(--text-dim); cursor:grab; font-size:18px; line-height:1; }
        .field-info  { flex:1; }
        .field-label { font-size:14px; font-weight:600; }
        .field-type  { font-size:12px; color:var(--text-dim); }
        .field-actions { display:flex; gap:6px; }
        .add-field-row { display:flex; gap:10px; align-items:flex-end; flex-wrap:wrap; }
        .submissions-preview { max-height:320px; overflow-y:auto; }
    </style>
</head>
<body>

<div id="sidebarOverlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.3); z-index:199;"
     onclick="document.getElementById('sidebar').classList.remove('open'); this.style.display='none'"></div>

<div class="app-shell">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="sidebar-logo-mark">&#9670;</div>
            <div><div class="sidebar-logo-text">Club Portal</div><div class="sidebar-logo-sub">Admin Panel</div></div>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-section-label">Main</div>
            <ul class="sidebar-nav">
                <li><a href="dashboard.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M2 11l8-8 8 8v8a1 1 0 01-1 1H3a1 1 0 01-1-1v-8z"/></svg>Dashboard</a></li>
                <li><a href="students.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zm8 0a3 3 0 11-6 0 3 3 0 016 0zM9 13a6 6 0 00-6 6h12a6 6 0 00-6-6z"/></svg>Students</a></li>
            </ul>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-section-label">Manage</div>
            <ul class="sidebar-nav">
                <li><a href="attendance.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>Attendance</a></li>
                <li><a href="meetings.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>Meetings</a></li>
                <li><a href="form-builder.html" class="active"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>Data Form</a></li>
            </ul>
        </div>
        <div class="sidebar-footer">
            <div class="sidebar-user" onclick="logout()">
                <div class="avatar">A</div>
                <div class="sidebar-user-info"><div class="sidebar-user-name">Admin</div><div class="sidebar-user-role">Club Admin</div></div>
            </div>
        </div>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <div style="display:flex; align-items:center; gap:12px;">
                <button class="topbar-menu-btn" id="menuBtn"><svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/></svg></button>
                <div class="topbar-left">
                    <div class="page-title">Data Collection Form</div>
                    <div class="page-breadcrumb">Design the form students fill in</div>
                </div>
            </div>
            <div class="topbar-right">
                <button class="btn btn-primary" onclick="saveForm()">Save Form</button>
            </div>
        </div>

        <div class="page-body">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">

                <!-- Builder -->
                <div>
                    <div class="panel" style="margin-bottom:16px;">
                        <div class="panel-header"><div class="panel-title">Form Fields</div></div>
                        <div class="panel-body">
                            <div id="fieldsList"></div>
                            <div class="add-field-row" style="margin-top:12px;">
                                <div class="form-group" style="flex:2;">
                                    <label>Field label</label>
                                    <input type="text" id="newFieldLabel" placeholder="e.g. Year of study">
                                </div>
                                <div class="form-group" style="flex:1;">
                                    <label>Type</label>
                                    <select id="newFieldType">
                                        <option value="text">Short text</option>
                                        <option value="email">Email</option>
                                        <option value="tel">Phone</option>
                                        <option value="date">Date</option>
                                        <option value="select">Dropdown</option>
                                        <option value="textarea">Long text</option>
                                    </select>
                                </div>
                                <button class="btn btn-primary" style="align-self:flex-end;" onclick="addField()">Add</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Live preview -->
                <div>
                    <div class="panel">
                        <div class="panel-header">
                            <div class="panel-title">Live Preview</div>
                            <span class="badge badge-green">Student view</span>
                        </div>
                        <div class="panel-body">
                            <p style="font-size:13px; color:var(--text-dim); margin-bottom:16px;">This is what students will see when they fill in the form.</p>
                            <div id="formPreview" class="form-grid"></div>
                        </div>
                    </div>

                    <!-- Submissions -->
                    <div class="panel" style="margin-top:16px;">
                        <div class="panel-header">
                            <div class="panel-title">Submissions</div>
                            <span class="badge badge-gray" id="subCount">0</span>
                        </div>
                        <div class="submissions-preview" id="submissionsArea">
                            <div class="empty-state" style="padding:30px 20px;">
                                <div class="empty-icon">📬</div>
                                <div class="empty-title">No submissions yet</div>
                                <div class="empty-desc">Students haven't filled in the form yet</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="../js/app.js"></script>
<script>
    requireAuth('admin');

    /* Default fields every form starts with */
    let fields = [
        { label: 'Full Name',   type: 'text',   required: true },
        { label: 'Student ID',  type: 'text',   required: true },
        { label: 'Email',       type: 'email',  required: true },
        { label: 'Class / Year',type: 'text',   required: false },
    ];

    const typeLabels = { text:'Short text', email:'Email', tel:'Phone', date:'Date', select:'Dropdown', textarea:'Long text' };

    function renderFields() {
        const el = document.getElementById('fieldsList');
        el.innerHTML = fields.map((f, i) => `
            <div class="field-card">
                <div class="field-drag">&#8801;</div>
                <div class="field-info">
                    <div class="field-label">${f.label} ${f.required ? '<span style="color:var(--red)">*</span>' : ''}</div>
                    <div class="field-type">${typeLabels[f.type]}</div>
                </div>
                <div class="field-actions">
                    <button class="btn btn-secondary btn-sm" onclick="toggleRequired(${i})">${f.required ? 'Optional' : 'Required'}</button>
                    <button class="btn btn-danger btn-sm" onclick="removeField(${i})" ${fields.length <= 1 ? 'disabled' : ''}>&#x2715;</button>
                </div>
            </div>
        `).join('');
        renderPreview();
    }

    function renderPreview() {
        const el = document.getElementById('formPreview');
        el.innerHTML = fields.map(f => `
            <div class="form-group">
                <label>${f.label}${f.required ? ' <span style="color:var(--red)">*</span>' : ''}</label>
                ${f.type === 'textarea'
                    ? `<textarea placeholder="Enter ${f.label.toLowerCase()}…" disabled></textarea>`
                    : f.type === 'select'
                    ? `<select disabled><option>Select an option…</option></select>`
                    : `<input type="${f.type}" placeholder="Enter ${f.label.toLowerCase()}…" disabled>`
                }
            </div>
        `).join('');
    }

    function addField() {
        const label = document.getElementById('newFieldLabel').value.trim();
        const type  = document.getElementById('newFieldType').value;
        if (!label) { showAlert('Enter a field label.', 'error'); return; }
        fields.push({ label, type, required: false });
        renderFields();
        document.getElementById('newFieldLabel').value = '';
    }

    function removeField(i) { fields.splice(i, 1); renderFields(); }
    function toggleRequired(i) { fields[i].required = !fields[i].required; renderFields(); }

    function saveForm() {
        /* Will save to Supabase in Phase 2 */
        localStorage.setItem('clubFormFields', JSON.stringify(fields));
        showAlert('Form saved! Students can now fill it in.', 'success');
    }

    /* Load saved form if it exists */
    const saved = localStorage.getItem('clubFormFields');
    if (saved) { try { fields = JSON.parse(saved); } catch(e) {} }

    renderFields();

    document.getElementById('menuBtn').addEventListener('click', () => {
        const s = document.getElementById('sidebar');
        const o = document.getElementById('sidebarOverlay');
        s.classList.toggle('open');
        o.style.display = s.classList.contains('open') ? 'block' : 'none';
    });
</script>
</body>
</html>
