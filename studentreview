<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../css/app.css">
</head>
<body>

<div id="sidebarOverlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.3); z-index:199;"
     onclick="document.getElementById('sidebar').classList.remove('open'); this.style.display='none'"></div>

<div class="app-shell">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="sidebar-logo-mark">&#9670;</div>
            <div><div class="sidebar-logo-text">Club Portal</div><div class="sidebar-logo-sub">Admin Panel</div></div>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-section-label">Main</div>
            <ul class="sidebar-nav">
                <li><a href="dashboard.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M2 11l8-8 8 8v8a1 1 0 01-1 1H3a1 1 0 01-1-1v-8z"/></svg>Dashboard</a></li>
                <li><a href="students.html" class="active"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zm8 0a3 3 0 11-6 0 3 3 0 016 0zM9 13a6 6 0 00-6 6h12a6 6 0 00-6-6z"/></svg>Students</a></li>
            </ul>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-section-label">Manage</div>
            <ul class="sidebar-nav">
                <li><a href="attendance.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>Attendance</a></li>
                <li><a href="meetings.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>Meetings</a></li>
                <li><a href="form-builder.html"><svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>Data Form</a></li>
            </ul>
        </div>
        <div class="sidebar-footer">
            <div class="sidebar-user" onclick="logout()">
                <div class="avatar">A</div>
                <div class="sidebar-user-info"><div class="sidebar-user-name">Admin</div><div class="sidebar-user-role">Club Admin</div></div>
            </div>
        </div>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <div style="display:flex; align-items:center; gap:12px;">
                <button class="topbar-menu-btn" id="menuBtn"><svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/></svg></button>
                <div class="topbar-left">
                    <div class="page-title">Students</div>
                    <div class="page-breadcrumb">Manage club members</div>
                </div>
            </div>
            <div class="topbar-right">
                <button class="btn btn-primary" onclick="openModal('addStudentModal')">+ Add Student</button>
            </div>
        </div>

        <div class="page-body">
            <!-- Search bar -->
            <div style="margin-bottom:16px;">
                <input type="text" id="searchInput" placeholder="Search by name or student ID…" oninput="renderStudents()" style="max-width:360px;">
            </div>

            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title">All Members</div>
                    <span class="badge badge-blue" id="studentCount">0 students</span>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Student ID</th>
                                <th>Email</th>
                                <th>Class</th>
                                <th>Joined</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="studentsTable"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Student Modal -->
<div class="modal-overlay" id="addStudentModal">
    <div class="modal">
        <div class="modal-header">
            <div class="modal-title">Add Student</div>
            <button class="modal-close" onclick="closeModal('addStudentModal')">&#x2715;</button>
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" id="sName" placeholder="e.g. Alice Tan">
            </div>
            <div class="form-grid form-grid-2">
                <div class="form-group">
                    <label>Student ID</label>
                    <input type="text" id="sId" placeholder="e.g. S12345">
                </div>
                <div class="form-group">
                    <label>Class</label>
                    <input type="text" id="sClass" placeholder="e.g. 3A">
                </div>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" id="sEmail" placeholder="student@school.edu">
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('addStudentModal')">Cancel</button>
            <button class="btn btn-primary" onclick="addStudent()">Add Student</button>
        </div>
    </div>
</div>

<script src="../js/app.js"></script>
<script>
    requireAuth('admin');
    let students = [];

    function renderStudents() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        const filtered = students.filter(s =>
            s.name.toLowerCase().includes(q) || s.studentId.toLowerCase().includes(q)
        );
        const tbody = document.getElementById('studentsTable');
        document.getElementById('studentCount').textContent = `${students.length} students`;
        if (!filtered.length) {
            tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state"><div class="empty-icon">👤</div><div class="empty-title">${students.length ? 'No results' : 'No students yet'}</div><div class="empty-desc">Add your first club member</div></div></td></tr>`;
            return;
        }
        tbody.innerHTML = filtered.map((s, i) => `
            <tr>
                <td><div style="display:flex;align-items:center;gap:10px;"><div class="avatar" style="width:32px;height:32px;font-size:13px;">${s.name[0]}</div><strong>${s.name}</strong></div></td>
                <td><code style="background:var(--surface);padding:2px 7px;border-radius:5px;font-size:13px;">${s.studentId}</code></td>
                <td>${s.email || '—'}</td>
                <td>${s.class || '—'}</td>
                <td>${formatDate(s.joined)}</td>
                <td><button class="btn btn-danger btn-sm" onclick="removeStudent(${i})">Remove</button></td>
            </tr>
        `).join('');
    }

    function addStudent() {
        const name = document.getElementById('sName').value.trim();
        const id   = document.getElementById('sId').value.trim();
        if (!name || !id) { showAlert('Name and Student ID are required.', 'error'); return; }
        students.push({ name, studentId: id, email: document.getElementById('sEmail').value, class: document.getElementById('sClass').value, joined: new Date().toISOString().split('T')[0] });
        renderStudents();
        closeModal('addStudentModal');
        showAlert(`${name} added!`, 'success');
        ['sName','sId','sEmail','sClass'].forEach(x => document.getElementById(x).value = '');
    }

    function removeStudent(i) {
        if (!confirm('Remove this student?')) return;
        students.splice(i, 1);
        renderStudents();
    }

    renderStudents();

    document.getElementById('menuBtn').addEventListener('click', () => {
        const s = document.getElementById('sidebar');
        const o = document.getElementById('sidebarOverlay');
        s.classList.toggle('open');
        o.style.display = s.classList.contains('open') ? 'block' : 'none';
    });
</script>
</body>
</html>
